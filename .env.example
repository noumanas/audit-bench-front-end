# Base URL of the backend API. Baked into the client bundle at build time —
# changing it requires a rebuild (or a build ARG when using Docker).
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Canonical public URL of this site — used for SEO metadata (canonical URLs,
# Open Graph, sitemap, robots.txt). Server-only, read at build time for
# static pages, so it does NOT need the NEXT_PUBLIC_ prefix.
SITE_URL="https://audit-bench-app-242355763105.europe-west1.run.app"
